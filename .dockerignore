ui/
sdk-node/
node_modules/

# Secrets and local config — never bake into the image
.env
.env.*
!.env.example

# Git
.git/
.gitignore

# Editor / OS
.idea/
.vscode/
*.swp
.DS_Store

# Docker files themselves
Dockerfile*
docker-compose*.yml
