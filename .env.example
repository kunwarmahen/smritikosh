# ─── LLM (chat/extraction) ────────────────────────────────────────────────────
# Provider: claude | openai | gemini | ollama | vllm | llamacpp
LLM_PROVIDER=claude
LLM_MODEL=claude-haiku-4-5-20251001
LLM_API_KEY=your_anthropic_key_here
# Only needed for ollama / vllm / llamacpp:
# LLM_BASE_URL=http://localhost:11434      # ollama
# LLM_BASE_URL=http://localhost:8000/v1   # vllm
# LLM_BASE_URL=http://localhost:8080/v1   # llamacpp (llama-server default port)
# LLM_MAX_TOKENS=                       # leave unset for no limit

# ─── LLM fallback provider (optional) ────────────────────────────────────────
# When the primary LLM is unavailable or rate-limited, retries are attempted
# against this provider before the request fails.  Leave unset to disable.
# Example: primary = claude, fallback = openai (gpt-4o-mini)
# LLM_FALLBACK_PROVIDER=openai
# LLM_FALLBACK_MODEL=gpt-4o-mini
# LLM_FALLBACK_API_KEY=your_openai_key_here   # only if different from LLM_API_KEY
# LLM_FALLBACK_BASE_URL=                       # for local fallback providers

# ─── Embeddings ───────────────────────────────────────────────────────────────
# Provider: openai | ollama | vllm | gemini | llamacpp
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=your_openai_key_here
# EMBEDDING_BASE_URL=http://localhost:11434      # ollama: use nomic-embed-text
# EMBEDDING_MODEL=nomic-embed-text               # ollama embedding model
# EMBEDDING_BASE_URL=http://localhost:8080/v1    # llamacpp: start llama-server with --embedding --pooling mean
# EMBEDDING_MODEL=model-turbo                    # llamacpp: alias passed to llama-server
# EMBEDDING_DIMENSIONS=1536                      # must match your model (text-embedding-3-small=1536, nomic-embed-text=768, llamacpp/Qwen3=2048)

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_URL=postgresql+asyncpg://smritikosh:smritikosh@localhost:5432/smritikosh

# ─── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=smritikosh

# ─── App ──────────────────────────────────────────────────────────────────────
# APP_ENV controls runtime security enforcement. Non-production values
# (development, dev, local, test, testing, ci) relax secret checks to warnings.
# ANY OTHER value (e.g. "production", "staging") is treated as production: the
# app REFUSES TO BOOT if JWT_SECRET is the default or shorter than 32 chars.
APP_ENV=development
LOG_LEVEL=INFO
SQLALCHEMY_LOG_LEVEL=WARNING    # WARNING suppresses SQL noise; INFO to see queries; ERROR for errors only
# ENABLE_METRICS=true           # set to false to disable GET /metrics (Prometheus scraping); default true

# ─── Connectors ───────────────────────────────────────────────────────────────
# Slack Events API — required only if you use POST /ingest/slack/events
# Copy the "Signing Secret" from your Slack app's Basic Information page.
# SLACK_SIGNING_SECRET=your_slack_signing_secret_here

# Google OAuth2 connectors (Gmail + Google Calendar) — optional
# Set up a new OAuth2 application at https://console.cloud.google.com/:
#   1. Create a new OAuth2 application (Desktop app type).
#   2. Grant permissions: Gmail API (gmail.readonly), Calendar API (calendar.readonly).
#   3. Create an OAuth2 credential (Desktop app) and download the JSON.
# GOOGLE_CLIENT_ID=your_google_client_id_here
# GOOGLE_CLIENT_SECRET=your_google_client_secret_here
# GOOGLE_REDIRECT_URI=http://localhost:8080/connectors/google/callback
# For production, change GOOGLE_REDIRECT_URI to your server's FQDN.

# ─── Audit trail (MongoDB) ────────────────────────────────────────────────────
# Leave unset to disable audit trail — system runs without it.
# MONGODB_URL=mongodb://localhost:27017
# MONGODB_DB_NAME=smritikosh_audit

# ─── Auth (UI login) ──────────────────────────────────────────────────────────
# Generate a strong secret:  python -c "import secrets; print(secrets.token_hex(32))"
# REQUIRED in production: must be changed from the default and at least 32 chars,
# or the app refuses to start (see APP_ENV above).
JWT_SECRET=change-me-in-production
# JWT_ALGORITHM=HS256
# JWT_EXPIRE_DAYS=30

# Key for encrypting connector OAuth tokens (Gmail / Calendar) at rest.
# If unset, the key is derived from JWT_SECRET (backward compatible). Set this
# so the JWT secret and the connector-token key can be rotated independently.
#   Generate:  python -c "import secrets; print(secrets.token_hex(32))"
# WARNING: setting this on a deployment that already has connector tokens makes
# those tokens undecryptable until each user re-authorises the connector.
# CONNECTOR_ENCRYPTION_KEY=

# Set to 1 temporarily to allow the first admin registration without a token.
# Remove immediately after creating the first account.
# BOOTSTRAP_ADMIN=0

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API from a browser.
# Leave unset (default) to send no CORS headers — browsers then block
# cross-origin calls. Server-side clients (SDKs, the Next.js dashboard proxy)
# are unaffected. Set "*" only for a credential-less public API; the wildcard
# automatically disables credentials, as required by the CORS spec.
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# ─── Redis ────────────────────────────────────────────────────────────────────
# Shared store for the rate limiter AND the durable task queue (ARQ).
#  - Rate limiter: if unset, falls back to per-process in-memory storage — fine
#    for a single instance, REQUIRED once you run more than one API replica.
#  - Task queue: if unset, media processing / bulk re-embed run in-process as
#    FastAPI background tasks (lost on restart). With Redis set, they run on the
#    durable queue — run the worker with: arq smritikosh.tasks.jobs.WorkerSettings
# REDIS_URL=redis://localhost:6379/0

# ─── Worker metrics ───────────────────────────────────────────────────────────
# Prometheus /metrics port for the standalone worker (job runs/durations,
# LLM tokens/cost from background jobs). 0 or unset = disabled. The API
# process always exposes /metrics regardless.
# WORKER_METRICS_PORT=9090

# ─── Rate limiting ────────────────────────────────────────────────────────────
# Per-user limits. Format: "<count>/<period>" — e.g. "60/minute", "1000/hour"
# Set to "" to disable rate limiting entirely.
# RATE_LIMIT_ENCODE=60/minute
# RATE_LIMIT_CONTEXT=60/minute
# RATE_LIMIT_SEARCH=120/minute

# ─── Usage quotas ─────────────────────────────────────────────────────────────
# Default per-tenant caps applied to every (user_id, app_id) without an
# explicit override (set overrides via PUT /admin/quotas/{user_id}).
# 0 = unlimited. Event limits count stored events; token limits sum LLM
# prompt+completion tokens (requires the llm_usage accounting, on by default).
# Windows are UTC-calendar: daily resets at midnight, monthly on the 1st.
# Exceeding a cap returns HTTP 429 with a quota-specific message.
# QUOTA_DEFAULT_DAILY_EVENTS=0
# QUOTA_DEFAULT_MONTHLY_EVENTS=0
# QUOTA_DEFAULT_DAILY_TOKENS=0
# QUOTA_DEFAULT_MONTHLY_TOKENS=0

# ─── Semantic fact decay ──────────────────────────────────────────────────────
# Confidence halves every N days without reinforcement (exponential decay).
# Relationships below the floor are deleted; orphaned Fact nodes cleaned up automatically.
# FACT_DECAY_HALF_LIFE_DAYS=60.0
# FACT_DECAY_FLOOR=0.1

# ─── Media ingestion (Whisper transcription) ──────────────────────────────────
# Provider: "openai" (cloud, requires API key) or "local" (self-hosted, requires base URL)
WHISPER_PROVIDER=openai
# For OpenAI: use your OpenAI API key (or defaults to EMBEDDING_API_KEY)
# WHISPER_API_KEY=your_openai_key_here
# For local (ollama/vllm/llamacpp): URL to the Whisper service
# WHISPER_BASE_URL=http://localhost:8000/v1  # vllm
# WHISPER_BASE_URL=http://localhost:11434    # ollama
# WHISPER_BASE_URL=http://localhost:8080/v1  # llama-server (llamacpp)
# WHISPER_MODEL=whisper-1  # OpenAI model; for local use model name deployed at base URL
# MEDIA_MAX_AUDIO_MB=25
# MEDIA_MAX_DOCUMENT_MB=10
# MEDIA_MAX_DOCUMENT_PAGES=50
# MEDIA_MAX_IMAGE_MB=20

# ─── Vision model (image description — Phase 11) ─────────────────────────────
# Used to describe uploaded images (receipts, screenshots, whiteboards) before
# memory extraction. Must support multimodal (image) inputs.
# Provider: "openai" (cloud, gpt-4o-mini) | "claude" (Anthropic) | "ollama" (local)
VISION_PROVIDER=openai
VISION_MODEL=gpt-4o-mini
# VISION_API_KEY=your_openai_key_here   # defaults to LLM_API_KEY if unset
# VISION_BASE_URL=http://localhost:11434  # for local providers (ollama, vllm)

# ─── Speaker diarization (Phase 12 — meeting recordings) ─────────────────────
# Provider: "none" (default, first-person filter only) | "pyannote"
# "pyannote" requires:
#   pip install pyannote.audio torch
#   HF_TOKEN below (read access to pyannote/speaker-diarization-3.1)
DIARIZATION_PROVIDER=none
# HF_TOKEN=your_huggingface_token_here   # https://huggingface.co/settings/tokens
# SPEAKER_SIMILARITY_THRESHOLD=0.75      # cosine similarity threshold for voice matching
# MEDIA_MAX_MEETING_MB=500               # max meeting recording size in MB
#
# For speaker embedding (voice enrollment d-vector):
#   pip install resemblyzer
# Without resemblyzer: enrollment is recorded but matching is disabled.

# ─── Background scheduler ─────────────────────────────────────────────────────
# Whether THIS process runs the memory-maintenance jobs (consolidation, pruning,
# clustering, belief mining, fact decay, synthesis).
#   true  — single-process / development: the API process runs the jobs (default).
#   false — multi-replica: run a dedicated worker instead:
#               python -m smritikosh.worker.main
#           and set RUN_SCHEDULER=false on the API replicas.
# A Postgres advisory lock elects ONE leader regardless of this flag, so leaving
# it true on several replicas is safe — only the lock holder runs jobs.
# RUN_SCHEDULER=true

# How many tenants a background job processes concurrently. Each slot holds
# its own Postgres + Neo4j session and may make LLM calls — size against pool
# limits and provider rate limits.
# SCHEDULER_JOB_CONCURRENCY=4

# ─── Scheduler (cron expressions, UTC) ───────────────────────────────────────
# Standard 5-field cron: minute hour day-of-month month day-of-week
# SCHEDULER_CONSOLIDATION_CRON="0 * * * *"    # hourly
# SCHEDULER_PRUNING_CRON="0 2 * * *"          # daily at 02:00 UTC
# SCHEDULER_CLUSTERING_CRON="0 */6 * * *"     # every 6 hours
# SCHEDULER_BELIEF_MINING_CRON="0 */12 * * *" # every 12 hours
# SCHEDULER_FACT_DECAY_CRON="0 3 * * 0"       # weekly, Sunday 03:00 UTC
