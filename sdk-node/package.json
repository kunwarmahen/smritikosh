{
  "name": "smritikosh",
  "version": "0.1.0",
  "description": "Node.js SDK for the Smritikosh universal AI memory layer",
  "keywords": ["ai", "memory", "llm", "rag", "smritikosh"],
  "license": "MIT",
  "engines": { "node": ">=18.0.0" },

  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },

  "files": ["dist", "src"],

  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },

  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  }
}
