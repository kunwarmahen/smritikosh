# sample/.env  — copy this file to .env and fill in your values.
# Settings here override the project-root .env, so you only need to set
# what you want to change (e.g. switch the active user without touching .env).

# ── Active user ────────────────────────────────────────────────────────────────
# Which user the chatbot logs in as and stores/reads memories for.
# Built-in demo users: alice, priya
SMRITIKOSH_USER=alice
SMRITIKOSH_USER_PASS=alicepass

# Or use an API key instead of username/password (takes priority if set):
# SMRITIKOSH_API_KEY=sk-smriti-your-key-here

# ── Smritikosh server ──────────────────────────────────────────────────────────
# SMRITIKOSH_URL=http://localhost:8080

# ── LLM provider ──────────────────────────────────────────────────────────────
# Options: ollama | openai | anthropic | gemini
# LLM_PROVIDER=ollama
# LLM_MODEL=qwen2.5:14b
# LLM_BASE_URL=http://localhost:11434
# LLM_API_KEY=
